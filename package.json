{
  "name": "kth-node-publications-formatters",
  "version": "3.0.0",
  "description": "This is a utility library for formatting publications in publications-web/api",
  "automaticPublish": "true",
  "main": "index.js",
  "files": [
    "index.js",
    "helpers"
  ],
  "scripts": {
    "lint": "eslint --quiet",
    "lint-v": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "build": "npm ci",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KTH/kth-node-publications-formatters.git"
  },
  "keywords": [],
  "author": {
    "name": "KTH",
    "email": "infosys@kth.se",
    "url": "https://github.com/KTH"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/KTH/kth-node-publications-formatters/issues"
  },
  "homepage": "https://github.com/KTH/kth-node-publications-formatters#readme",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@kth/eslint-config-kth": "^4.1.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4"
  },
  "peerDependencies": {
    "@kth/log": ">=4.0.8"
  },
  "prettier": {
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": false,
    "singleQuote": true,
    "printWidth": 120
  },
  "jest": {
    "clearMocks": true,
    "notifyMode": "failure-change",
    "testEnvironment": "node",
    "verbose": true,
    "testMatch": [
      "**/test/**/*Test.js"
    ]
  }
}
